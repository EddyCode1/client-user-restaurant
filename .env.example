# IP de tu máquina (para dispositivo físico) o localhost para emulador/web
EXPO_PUBLIC_DEV_HOST=localhost

# Puerto del backend GestorRestaurante (Node/Express)
EXPO_PUBLIC_API_PORT=3006

# URLs completas (opcional; si no se definen, se construyen con DEV_HOST + API_PORT)
EXPO_PUBLIC_AUTH_URL=http://localhost:3006/GestorRestaurante/v1/auth
EXPO_PUBLIC_API_BASE=http://localhost:3006/GestorRestaurante/v1

# API bancaria (opcional, solo si usas módulos de banca)
EXPO_PUBLIC_BANKING_API_BASE=http://localhost:3000/SistemaBancarioAdmin/v1
